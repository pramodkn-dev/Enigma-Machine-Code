<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>PriceHub.Service</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- gRPC runtime + reflection + JSON transcoding -->
    <PackageReference Include="Grpc.AspNetCore" Version="2.*" />
    <PackageReference Include="Grpc.AspNetCore.Server.Reflection" Version="2.*" />
    <PackageReference Include="Microsoft.AspNetCore.Grpc.JsonTranscoding" Version="8.*" />
    <PackageReference Include="Google.Api.CommonProtos" Version="2.*" />
    <PackageReference Include="Grpc.Tools" Version="2.*" PrivateAssets="All" />
    <!-- Data layer placeholders -->
    <PackageReference Include="Oracle.ManagedDataAccess.Core" Version="3.*" />
    <PackageReference Include="Dapper" Version="2.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- Compile the service proto; provide Server stubs -->
    <Protobuf Include="Protos\price.proto" GrpcServices="Server" />
    <Protobuf Include="Protos\google\api\*.proto" GrpcServices="None" />
  </ItemGroup>

</Project>
